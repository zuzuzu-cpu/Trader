# ═══════════════════════════════════════════════════════════
# SENTINEL AUTOTRADER V3.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# ─── Alpaca Paper Trading API ────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ─── DeepSeek AI (OpenAI-compatible) ─────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── News API (free tier: 100 req/day) ───────────────────
NEWSAPI_KEY=your_newsapi_key

# ─── Optional: Additional Data Sources ───────────────────
COINMARKETCAP_API_KEY=your_cmc_api_key
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# ─── Trading Parameters ─────────────────────────────────
CONFIDENCE_THRESHOLD=70         # Minimum confidence % to execute a trade
MAX_POSITION_PCT=0.02           # Max 2% of equity per trade
MAX_PORTFOLIO_POSITIONS=25      # Max concurrent positions
MAX_SECTOR_CONCENTRATION=0.30   # Max 30% in one sector
MAX_DRAWDOWN_PCT=0.15           # 15% drawdown → circuit breaker halts trading
TRAILING_STOP_PCT=3.0           # Default trailing stop %
ATR_RISK_MULTIPLIER=1.5         # Trailing stop = ATR × this multiplier

# ─── Scoring Weights ────────────────────────────────────
WEIGHT_QUANT=0.40               # Quant score weight
WEIGHT_SENTIMENT=0.35           # Sentiment score weight
WEIGHT_RISK=0.25                # Risk score weight

# ─── Scheduler ──────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30        # Run a full cycle every N minutes
TRADE_EXTENDED_HOURS=true       # Trade during pre/post-market

# ─── Rate Limits ────────────────────────────────────────
ALPACA_RATE_LIMIT=180           # Alpaca: 200 max, keep buffer
DEEPSEEK_RATE_LIMIT=30          # DeepSeek: dynamic, be conservative
NEWSAPI_RATE_LIMIT=90           # NewsAPI: 100/day free tier

# ─── Universe Filters ──────────────────────────────────
MIN_PRICE=5.0
MAX_PRICE=10000.0
MIN_DAILY_VOLUME=500000
MIN_MARKET_CAP=500000000

# ─── Quant Engine ──────────────────────────────────────
LOOKBACK_DAYS=120               # Days of historical data for indicators
QUANT_PASS_SCORE=55             # Minimum quant score to pass to AI agents
